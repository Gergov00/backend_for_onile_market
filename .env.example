# Military Shop - Переменные окружения (Пример)

# Настройки базы данных PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin
DB_NAME=military_shop

# Настройки SMS (Notificore)
# Оставьте пустым для mock-режима (вывод в консоль)
NOTIFICORE_API_KEY=test_api_key_here
SMS_ORIGINATOR="Info"

# Настройки сервера
SERVER_PORT=8080

# JWT Секрет (Обязательно смените на сложную строку в production!)
JWT_SECRET=your-super-long-randomly-generated-secret-key-here

# Настройки SMTP (Beget/GMail/etc)
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_USER=no-reply@your-domain.org
SMTP_PASSWORD="your-strong-password"
SMTP_FROM=no-reply@your-domain.org
